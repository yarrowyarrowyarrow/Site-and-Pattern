+import { create } from "zustand";
+
+// Sun position driving the scene's shadow-casting light. Angles follow the
+// usual convention so a desktop host (e.g. PermaDesign's sun-path engine,
+// src/solar.py) can push values straight from its own solar calculation:
+//   azimuthDeg  — degrees clockwise from north (0 = N, 90 = E, 180 = S, 270 = W)
+//   altitudeDeg — degrees above the horizon (0 = horizon, 90 = zenith)
+type SunStore = {
+  azimuthDeg: number;
+  altitudeDeg: number;
+  setSun: (azimuthDeg: number, altitudeDeg: number) => void;
+};
+
+export const useSunStore = create<SunStore>((set) => ({
+  // Default: an oblique mid-morning southern sun, so shadows are clearly
+  // visible out of the box even before a host drives the angles.
+  azimuthDeg: 150,
+  altitudeDeg: 40,
+  setSun: (azimuthDeg, altitudeDeg) => set(() => ({ azimuthDeg, altitudeDeg })),
+}));
+
+// Bridge hook: let the embedding desktop app set the sun from its own sun-path
+// (over the QWebChannel bridge), e.g. window.permaSetSun(azimuthDeg, altitudeDeg).
+// No-op cost when running standalone in a normal browser.
+if (typeof window !== "undefined") {
+  (window as unknown as Record<string, unknown>).permaSetSun = (
+    azimuthDeg: number,
+    altitudeDeg: number
+  ) => useSunStore.getState().setSun(azimuthDeg, altitudeDeg);
+}
