+// Scene axes (see project() below): +X = east, +Y = up, +Z = south, because
+// north (v.y) is mapped to -Z. Convert a sun azimuth (deg clockwise from north)
+// and altitude (deg above the horizon) into the direction the sun shines FROM.
+function sunVector(azimuthDeg: number, altitudeDeg: number) {
+  const az = (azimuthDeg * Math.PI) / 180;
+  const alt = (altitudeDeg * Math.PI) / 180;
+  const east = Math.sin(az) * Math.cos(alt);
+  const north = Math.cos(az) * Math.cos(alt);
+  const up = Math.sin(alt);
+  return new THREE.Vector3(east, up, -north);
+}
+
+// The sun: a shadow-casting directional light whose direction tracks the sun
+// store (the defaults when standalone, or values pushed by the host via
+// window.permaSetSun). A matching drei <Sky> keeps the visible sun aligned with
+// the shadow direction. The orthographic shadow frustum is sized to the scene
+// (radius) so shadows stay sharp and fully covered.
+function Sun({ radius }: { radius: number }) {
+  const azimuthDeg = useSunStore((s) => s.azimuthDeg);
+  const altitudeDeg = useSunStore((s) => s.altitudeDeg);
+  const dir = sunVector(azimuthDeg, Math.max(2, altitudeDeg));
+  const dist = radius * 2.2;
+  return (
+    <>
+      <directionalLight
+        position={[dir.x * dist, dir.y * dist, dir.z * dist]}
+        intensity={2.2}
+        castShadow
+        shadow-mapSize-width={2048}
+        shadow-mapSize-height={2048}
+        shadow-camera-near={1}
+        shadow-camera-far={dist * 2.5}
+        shadow-camera-left={-radius}
+        shadow-camera-right={radius}
+        shadow-camera-top={radius}
+        shadow-camera-bottom={-radius}
+        shadow-bias={-0.0004}
+      />
+      <Sky distance={450000} sunPosition={[dir.x, dir.y, dir.z]} />
+    </>
+  );
+}
+
+// Transparent shadow-catcher ground: only darkens where shadows land, so the
+// existing sky/environment look is preserved while shadows become visible.
+function Ground({ radius }: { radius: number }) {
+  return (
+    <mesh rotation={[-Math.PI / 2, 0, 0]} receiveShadow>
+      <planeGeometry args={[radius * 4, radius * 4]} />
+      <shadowMaterial transparent opacity={0.35} />
+    </mesh>
+  );
+}
